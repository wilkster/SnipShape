      Return res
   }
   /**
    * Create an adjustable arrow cap for use as a pen end or start cap
    * @param length Distance from the base to the vertex of the arrow
    * @param width Distance between the two endpoints of the arrow base
    * @param isFilled 1 for a filled (block) arrow, 0 for outline only
    * @param Inset Optional middle inset value applied after creation
    * @returns {Ptr} Handle to the new adjustable arrow cap
    */
   Static CreateAdjustableArrowCap(length, width, isFilled := 1, Inset :=0) {
      if (res := DllCall("GdiPlus\GdipCreateAdjustableArrowCap"
         , "Float", length
