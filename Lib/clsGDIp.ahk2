   /**
    * Pack an array of float values into a Buffer suitable for use as a GDI+ color matrix
    * @param colorMatrixVals Array of float values (typically 25 for a 5x5 color matrix)
    * @returns {Buffer} Buffer containing the packed float values
    */
   Static GetMatrixBuffer(colorMatrixVals) {
      ColorMatrixBuf := Buffer(colorMatrixVals.Length * 4, 0)
      For Idx, Cmv in colorMatrixVals
         NumPut("float", Cmv, ColorMatrixBuf, (Idx - 1) * 4)
      Return ColorMatrixBuf
   }

