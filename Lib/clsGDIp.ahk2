   ; flatness - a precision value that specifies the maximum error between the path and
   ; its flattened [segmented] approximation. Reducing the flatness increases the number
   ; of line segments in the approximation. 
   ;
   ; hMatrix - a pointer to a transformation matrix to apply.
   /**
    * Flatten a path by converting curves to sequences of line segments
    * @param pPath Handle to the GraphicsPath
    * @param flatness Maximum error allowed between the path and its flattened approximation
    * @param hMatrix Optional transformation matrix to apply before flattening
    * @returns {Integer} GDI+ status code
    */
   Static FlattenPath(pPath, flatness, hMatrix:=0) {
      return DllCall("gdiplus\GdipFlattenPath", "Ptr", pPath, "Ptr", hMatrix, "float", flatness)
   }
      ; Replaces this path with curves that enclose the area that is filled when this path is drawn by a specified pen.
      ; This method also flattens the path.
   /**
    * Expand a path to the area that would be filled when drawn with a specific pen, then flatten it
    * @param pPath Handle to the GraphicsPath
    * @param pPen Pen that defines the widening
    * @param hMatrix Optional transformation matrix (default: 0)
    * @param Flatness Maximum error for the flattening approximation (default: 0.5)
    * @returns {Integer} GDI+ status code
    */
   Static WidenPath(pPath, pPen, hMatrix := 0, Flatness := 0.5) =>
      DllCall("gdiplus\GdipWidenPath", "Ptr", pPath, "uint", pPen, "Ptr", hMatrix, "float", Flatness)
   ; Transforms and flattens [segmentates] a pPath object, and then converts the path's data points
   ; so that they represent only the outline of the given path.
   ;
   ; flatness - a precision value that specifies the maximum error between the path and
   ; its flattened [segmented] approximation. Reducing the flatness increases the number
   ; of line segments in the resulted approximation. 
   ;
   ; hMatrix - a pointer to a transformation matrix to apply.
   /**
    * Transform, flatten, and convert a path to its outline only (removes interior fills)
    * @param pPath Handle to the GraphicsPath
    * @param flatness Maximum error for the outline approximation (default: 1)
    * @param hMatrix Optional transformation matrix to apply (default: 0)
    * @returns {Integer} GDI+ status code
    */
   Static PathOutline(pPath, flatness:=1, hMatrix:=0) {
      return DllCall("gdiplus\GdipWindingModeOutline", "Ptr", pPath, "Ptr", hMatrix, "float", flatness)
   }      
   ; Function				Static DrawLine
   ; Description			This function uses a pen to draw a line into the Graphics of a bitmap
   ;
   ; pGraphics				Pointer to the Graphics of a bitmap
   ; pPen					Pointer to a pen
   ; x1					x-coordinate of the start of the line
   ; y1					y-coordinate of the start of the line
   ; x2					x-coordinate of the end of the line
   ; y2					y-coordinate of the end of the line
   ;
   ; return				status enumeration. 0 = success
   /**
    * Draw a line between two points using the specified pen
    * @param pGraphics Handle to the Graphics object
    * @param pPen Handle to the Pen
    * @param x1 X coordinate of the start point
    * @param y1 Y coordinate of the start point
    * @param x2 X coordinate of the end point
    * @param y2 Y coordinate of the end point
    * @returns {Integer} GDI+ status code
    */
   Static DrawLine(pGraphics, pPen, x1, y1, x2, y2) {
      if (res := DllCall("gdiplus\GdipDrawLine"
         , "Ptr", pGraphics
         , "Ptr", pPen
         , "Float", x1
         , "Float", y1
         , "Float", x2
         , "Float", y2))
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
      Return res

   }
   ;#####################################################################################
   ; Function           CreatePointF
   ; Description        Creates a SizeF object, containing two values
   ;
   ; SizeF              Name to call the SizeF object
   ; x, y               x, y values for the SizeF object
   ;
   ; return             No Return value
   /**
    * Create a single floating-point point structure
    * @param {VarRef} PointF Returns a Buffer containing the X/Y float pair
    * @param x X coordinate
    * @param y Y coordinate
    */
   Static CreatePointF(&PointF, x, y) {
      PointF := Buffer(8)
      NumPut("Float", x, PointF, 0)
      NumPut("Float", y, PointF, 4)
   }
   /**
    * Create a buffer of floating-point points from a pipe-delimited "x,y|x,y" string
    * @param {VarRef} PointsF Returns the Buffer containing all point pairs
    * @param inPoints String of points in "x1,y1|x2,y2|..." format
    * @returns {Integer} Number of points parsed
    */
   Static CreatePointsF(&PointsF, inPoints) {
      Points := StrSplit(inPoints, "|")
      PointsCount := Points.Length
      PointsF := Buffer(8 * PointsCount, 0)
      For i, Point in Points {
         Coord := StrSplit(Point, ",")
         NumPut("Float", Coord[1], PointsF, 8 * (i - 1))
         NumPut("Float", Coord[2], PointsF, (8 * (i - 1)) + 4)
      }
      Return PointsCount
   }
   /**
    * Create an integer rectangle structure (stRECTI) from x, y, w, h values
    * @param {VarRef} RectI Returns the stRECTI structure
    * @param x Left coordinate
    * @param y Top coordinate
    * @param w Width
    * @param h Height
    */
   Static CreateRect(&RectI, x, y, w, h)   =>   NumPut("Uint", x, "Uint", y, "Uint", w, "Uint", h, RectI := stRECTI())
   /**
    * Create a floating-point rectangle structure (stRECTF) from x, y, w, h values
    * @param {VarRef} RectF Returns the stRECTF structure
    * @param x Left coordinate
    * @param y Top coordinate
    * @param w Width
    * @param h Height
    */
   Static CreateRectF(&RectF, x, y, w, h)   =>   NumPut("float", x, "float", y, "float", w, "float", h, RectF := stRECTF())
   /**
    * Update individual fields of an existing integer rectangle structure in place
    * @param RectI Existing stRECTI buffer to update
    * @param x Optional new left coordinate
    * @param y Optional new top coordinate
    * @param w Optional new width
    * @param h Optional new height
    */
   Static UpdateRect(RectI, x?, y?, w?, h?) {
      if IsSet(x)
         NumPut("Int", x, RectI, 0)
      if IsSet(y)
         NumPut("Int", y, RectI, 4)
      if IsSet(w)
         NumPut("Int", w, RectI, 8)
      if IsSet(h)
         NumPut("Int", h, RectI, 12)
   }

