    */
   Static DisposeEffect(pEffect) {
      if (res := DllCall("gdiplus\GdipDeleteEffect", "Ptr", pEffect))
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
      Return res
   }

   /*
      typedef enum DashStyle {
         DashStyleSolid, 0
         DashStyleDash, 1
         DashStyleDot, 2
         DashStyleDashDot, 3
         DashStyleDashDotDot, 4
         DashStyleCustom 5
   } ;
   */
   /**
    * Set the dash style for a pen
    * @param pPen Handle to the pen
    * @param dashStyle DashStyle value: 0=solid, 1=dash, 2=dot, 3=dash-dot, 4=dash-dot-dot, 5=custom
    * @returns {Integer} GDI+ status code
    */
   Static SetPenDashStyle(pPen, dashStyle) {
      if (res := DllCall("gdiplus\GdipSetPenDashStyle", "Ptr", pPen, "Uint", dashStyle))
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
      Return res
   }
   ; Description     Sets custom dashes and spaces for the pPen object.
   ;
   ; Parameters      pPen   - Pointer to a Pen object
   ;                 Dashes - The string that specifies the length of the custom dashes and spaces:
   ;                 Format: "dL1,sL1,dL2,sL2,dL3,sL3" [... and so on]
   ;                   dLn - Dash N length
   ;                   sLn - Space N length
   ;                 ExampleDashesArgument := "3,6,8,4,2,1"
   ;
   ; Remarks         This function sets the dash style for the pPen object to DashStyleCustom (6).
   ; Return status enumeration.
   /**
    * Set a custom dash pattern for a pen from a comma-delimited string of lengths
    * @param pPen Handle to the pen
    * @param Dashes Comma-separated string alternating dash and space lengths e.g. "3,6,8,4"
    * @returns {Integer} GDI+ status code
    */
   Static SetPenDashArray(pPen, Dashes) {

      Points := StrSplit(Dashes, ",")
      PointsCount := Points.Length
      PointsF := Buffer(8 * PointsCount, 0)
      Loop PointsCount
         NumPut("Float", Points[A_Index], PointsF, 4*(A_Index - 1))

      Return DllCall("gdiplus\GdipSetPenDashArray", "Ptr", pPen, "Ptr", PointsF.ptr, "int", PointsCount)
   }

   ; Sets the distance from the start of the line to the start of the first space in a dashed line
   ; Offset - Real number that specifies the number of times to shift the spaces in a dashed line. Each shift is
   ; equal to the length of a space in the dashed line
   /**
    * Set the starting offset of the dash pattern along a dashed line
    * @param pPen Handle to the pen
    * @param Offset Number of space-lengths to shift the start of the dash pattern
    * @returns {Integer} GDI+ status code
    */
   Static SetPenDashOffset(pPen, Offset) {

      Return DllCall("gdiplus\GdipSetPenDashOffset", "Ptr", pPen, "float", Offset)
   }
   ; DeleteGraphics
   /**
    * Delete a GDI+ Graphics object and free its resources
    * @param pGraphics Handle to the Graphics object to delete
    * @returns {Integer} GDI+ status code
    */
   Static DeleteGraphics(pGraphics) {
      if (res := DllCall("gdiplus\GdipDeleteGraphics", "Ptr", pGraphics))
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
      Return res
   }
   ; https://github.com/marius-sucan/AHK-GDIp-Library-Compilation/blob/master/ahk-v2/Gdip_All.ahk'
   /**
    * Specifies the alignment setting of the pen relative to the line that is drawn
    * @param Alignment  0 = Center of the line, 1 = One the inside of the line
    * @returns {Status}  OK if worked, 1->21 if fails (status enumeration)
    * 
    */
   Static SetPenAlignment(pPen, Alignment) {
      if (res := DllCall("gdiplus\GdipSetPenMode", "Ptr", pPen, "int", Alignment))
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
      Return res
   }
   /*
   Creates a region that is defined by a GraphicsPath object and has a fill mode
   that is contained in the GraphicsPath object.
   */
   /**
    * Create a GDI+ region from a GraphicsPath, using the path's own fill mode
    * @param pPath Handle to the GraphicsPath that defines the region
    * @returns {Ptr} Handle to the new region, or 0 on failure
    */
   Static CreateRegionPath(pPath) {
      ; Creates a region that is defined by a GraphicsPath [pPath object]. Written by Learning one.
      If (res := DllCall("gdiplus\GdipCreateRegionPath", "Ptr", pPath, "Ptr*", &Region:=0)) {
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
         Return 0
      } Else {
         return Region
      }
   }

   /**
    * Create a GDI+ region from a rectangular area
    * @param x Left coordinate
    * @param y Top coordinate
    * @param w Width
    * @param h Height
    * @returns {Ptr} Handle to the new region, or -1 on failure
    */
   Static CreateRegionRect(x, y, w, h) {
      this.CreateRectF(&RectF, x, y, w, h)
      Return (DllCall("gdiplus\GdipCreateRegionRect", "Ptr", RectF.ptr, "Ptr*", &Region := 0)) ? -1 : Region
   }
   /**
    * Delete a GDI+ region and free its resources
    * @param Region Handle to the region to delete
    * @returns {Integer} GDI+ status code
    */
   Static DeleteRegion(Region) {
      if (res := DllCall("gdiplus\GdipDeleteRegion", "Ptr", Region))
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
      Return res
   }

   /**
    * Expand a region to cover the entire infinite plane
    * @param Region Handle to the region to make infinite
    * @returns {Integer} GDI+ status code
    */
   Static SetInfiniteRegion(Region) {
      Return DllCall("gdiplus\GdipSetInfinite", "Ptr", Region)
   }
   
   /*
   The rectangle returned by this method might be larger than necessary to
   enclose the path as drawn by the specified pen. The rectangle is calculated
   to allow for the pen's miter limit at sharp corners and to allow for the
   pen's end caps.
   https://learn.microsoft.com/en-us/windows/win32/api/gdipluspath/nf-gdipluspath-graphicspath-getbounds(rect_constmatrix_constpen)
   */
   /**
    * Return the bounding rectangle of a GraphicsPath in world coordinates as floats
    * @param pPath Handle to the GraphicsPath
    * @param hMatrix Optional matrix to apply before computing bounds (default: 0)
    * @param pPen Optional pen whose width affects the bounds calculation (default: 0)
    * @returns {Object} Object with X, Y, W, H properties, or GDI+ status on failure
    */
   Static GetPathWorldBounds(pPath, hMatrix := 0, pPen := 0) {
      ; hMatrix to use for calculating the boundaries
      ; pPen to use for calculating the boundaries
      ; Both will not affect the actual GraphicsPath.
      RectF := stRECTF()
      res := DllCall("gdiplus\GdipGetPathWorldBounds", "Ptr", pPath, "Ptr", RectF.ptr, "Ptr", hMatrix, "Ptr", pPen)
      If (!res) {
         rData := { X: RectF.X1, Y: RectF.y1, W: RectF.X2, H: RectF.y2 }
         Return rData
      } Else {
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
         Return res
      }
   }

   /**
    * Return the bounding rectangle of a GraphicsPath in world coordinates as integers
    * @param pPath Handle to the GraphicsPath
    * @param pen Optional pen whose width affects the bounds (default: 0)
    * @param matrix Optional transformation matrix (default: 0)
    * @returns {Object} Object with X, Y, W, H properties, or GDI+ status on failure
    */
   Static GetPathWorldBoundsI(pPath, pen:=0, matrix := 0) {
      RectI := stRECTI()
      res := DllCall('Gdiplus\GdipGetPathWorldBoundsI', 'ptr', pPath, 'ptr', RectI.ptr, 'ptr', matrix, 'ptr', pen, 'uint')
      If (!res) {
         rData := { X: RectI.X1, Y: RectI.y1, W: RectI.X2, H: RectI.y2 }
         Return rData
      } Else {
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
         Return res
      }
   }
   /**
    * Return the bounding rectangle of a region in the coordinate space of a Graphics object (float)
    * @param pGraphics Handle to the Graphics object defining the coordinate space
    * @param Region Handle to the region
    * @returns {Object} Object with X, Y, W, H properties, or GDI+ status on failure
    */
   Static GetRegionBounds(pGraphics, Region) {
      RectF := stRECTF()
      res := DllCall("gdiplus\GdipGetRegionBounds", "Ptr", Region, "Ptr", pGraphics, "Ptr", RectF.ptr)
      If (!res) {
         rData := { X: RectF.X1, Y: RectF.Y1, W: RectF.X2, H: RectF.y2 }
         Return rData
      } Else {
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
         Return res
      }
   }
   /*
   Gets a rectangle that encloses this region.
   */
   /**
    * Return the bounding rectangle of a region in the coordinate space of a Graphics object (integer)
    * @param pGraphics Handle to the Graphics object defining the coordinate space
    * @param Region Handle to the region
    * @returns {Object} Object with X, Y, W, H properties, or GDI+ status on failure
    */
   Static GetRegionBoundsI(pGraphics, Region) {
      RectI := stRECTI()
      res := DllCall("gdiplus\GdipGetRegionBoundsI", "Ptr", Region, "Ptr", pGraphics, "Ptr", RectI.ptr)
      If (!res) {
         rData := { X: RectI.X1, Y: RectI.Y1, W: RectI.X2, H: RectI.y2 }
      } Else {
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
         Return res
      }
      Return rData
   }

   /**
    * Lock a rectangular area of a bitmap for direct pixel access
    * @param pBitmap Handle to the GDI+ bitmap
    * @param x Left of the lock rectangle
    * @param y Top of the lock rectangle
    * @param w Width of the lock rectangle
    * @param h Height of the lock rectangle
    * @param {VarRef} Stride Returns the stride (bytes per scan line) of the locked data
    * @param {VarRef} Scan0 Returns pointer to the first pixel of locked data
    * @param {VarRef} bmd Returns the BitmapData structure
    * @param LockMode Access flags: 1=read, 2=write, 3=read+write (default)
    * @param PixelFormat Pixel format for the locked data (default: 0x26200a = ARGB32)
    * @returns {Integer} GDI+ status code
    */
   Static LockBits(pBitmap, x, y, w, h, &Stride, &Scan0, &bmd, LockMode := 3, PixelFormat := 0x26200a) {
      this.CreateRect(&_Rect, x, y, w, h)
      bmd := BitmapData()
      if (res := DllCall("Gdiplus\GdipBitmapLockBits", "Ptr", pBitmap, "Ptr", _Rect.Ptr, "UInt", LockMode, "Int", PixelFormat, "Ptr", bmd))
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
      Stride := bmd.Stride
      Scan0  := bmd.Scan0
      Return res
   }
   /**
    * Unlock a bitmap region previously locked with LockBits
    * @param pBitmap Handle to the GDI+ bitmap
    * @param {VarRef} BitmapData BitmapData structure returned by LockBits
    * @returns {Integer} GDI+ status code
    */
   Static UnlockBits(pBitmap, &BitmapData) {
      if(res := DllCall("Gdiplus\GdipBitmapUnlockBits", "Ptr", pBitmap, "Ptr", BitmapData))
         Warning("GDI+ Error " GDIp.TranslateErrorCode(res))
      Return res
   }
}
;----------------------------------------------------------------------
; 2.1 Structures used herein
; Base Rectangle Structure
;----------------------------------------------------------------------
Struct baseStructure {
   CopyTo(objTarget) {
      ; Don't necessarly need the propery names to match, but they have to be the same size
      if (this.Size > 0 AND objTarget.Size = this.Size) {
         DllCall("RtlCopyMemory", IntPtr, objTarget.Ptr, IntPtr, this.Ptr, IntPtr, this.Size)
         Return 1
      } else  {
         Error("Object Size Mismatch on " this.__Class, -1, objTarget.__Class)
      }
   }
   ; Bug fix for alpha 22, Size doesn't work in nested structures
   ; Size => ObjGetDataSize(this) ; this will fix it but shouldn't be necessary
}
;----------------------------------------------------------------------
; Commonly used structures
;----------------------------------------------------------------------
; Provides Size/Ptr properties for commonality in DLL Calls
/**
 * Base class for all typed buffer structures, providing Size and Ptr properties
 * compatible with DllCall parameter passing
 * TODO - Alpha 22, no longer needed
 * TODO - Alpha 22, Class -> Struct
 */


/**
 * Base rectangle class providing w, h computed properties and a shift method.
 * for direct use in DllCall.
 */
Struct _clsRECT {
   ; For speed we don't use __New for every creation
   /**
    * Initialize the rectangle fields
    * @param x1 Left coordinate (default: 0)
    * @param y1 Top coordinate (default: 0)
    * @param x2 Right coordinate (default: 0)
    * @param y2 Bottom coordinate (default: 0)
    */
   Init(x1 := 0, y1 := 0, x2 := 0, y2 := 0) {
      this.x1 := x1
      this.y1 := y1
      this.x2 := x2
      this.y2 := y2
   }
   /**
    * Get or set the width (x2 - x1). Setting updates x2 to preserve x1.
    */
   w {
      get => Abs(this.x2 - this.x1)
      set {
         this.x2 := this.x1 + Value
      }
   }
   /**
    * Get or set the height (y2 - y1). Setting updates y2 to preserve y1.
    */
   h {
      get => Abs(this.y2 - this.y1)
      set {
         this.y2 := this.y1 + Value
      }
   }
   /**
    * Shift all four corners of the rectangle by the given delta values
    * @param x Horizontal offset to add to x1 and x2
    * @param y Vertical offset to add to y1 and y2
    */
   shift(x,y) {
      this.x1 += x
      this.x2 += x
      this.y1 += y
      this.y2 += y
   }
}
;----------------------------------------------------------------------
; Integer RECT structure
; stRECTI.Init(x1?,y1?,x2?,y2?) to initialize
; Returns Structure object
;----------------------------------------------------------------------
/**
 * Integer rectangle structure (RECT) for use in DllCall and GDI/GDI+ operations
 */
Struct stRECTI extends _clsRECT {
   x1: Int32
   y1: Int32
   x2: Int32
   y2: Int32
   ; Helper properties
}
;----------------------------------------------------------------------
; Floating RECT structure
; stRECTF.Init(x1?,y1?,x2?,y2?) to initialize
; Returns Structure object
;----------------------------------------------------------------------
/**
 * Floating-point rectangle structure (RectF) for use in GDI+ operations
 */
Struct stRECTF extends _clsRECT {
   x1: Float32
   y1: Float32
   x2: Float32
   y2: Float32
}
; https://learn.microsoft.com/en-us/previous-versions/ms534421(v=vs.85)
/**
 * GDI+ BitmapData structure, used with LockBits/UnlockBits to access raw pixel data
 */
Struct BitmapData {
   Width      : UInt32
   Height     : UInt32
   Stride     : Int32
   PixelFormat: UInt32
   Scan0      : IntPtr
   Reserved   : IntPtr
}
; https://learn.microsoft.com/en-us/windows/win32/api/wingdi/ns-wingdi-bitmap
; // ----------------------------------------------------------
; // 1. tagBITMAP  (the dsBm member of tagDIBSECTION)
; //    x86 size : 24 bytes
; //    x64 size : 32 bytes  (4 bytes padding before bmBits ptr)
; // ----------------------------------------------------------
; typedef struct tagBITMAP {
;     LONG    bmType;         // +0   4 bytes  — must be 0
;     LONG    bmWidth;        // +4   4 bytes  — width in pixels
;     LONG    bmHeight;       // +8   4 bytes  — height in pixels
;     LONG    bmWidthBytes;   // +12  4 bytes  — bytes per scan line (must be WORD-aligned)
;     WORD    bmPlanes;       // +16  2 bytes  — number of colour planes
;     WORD    bmBitsPixel;    // +18  2 bytes  — bits per pixel
;     // 4 bytes implicit padding here on x64 to align the pointer below
;     LPVOID  bmBits;         // +20 (x86) / +24 (x64)   — ptr to pixel data
;                             //  4 bytes on x86,  8 bytes on x64
; } BITMAP, *PBITMAP, *NPBITMAP, *LPBITMAP;
/**
 * GDI BITMAP structure, maps the tagBITMAP layout for use with GetObject
 */
Struct tagBITMAP {
   bmType      : Int32 ;0
   bmWidth     : Int32 ;4
   bmHeight    : Int32 ;8
   bmWidthBytes: Int32 ;16
   bmPlanes    : Int16 ;18
   bmBitsPixel : Int16 ; 20
   bmBits      : IntPtr ;28
}
; // ----------------------------------------------------------
; // 2. tagBITMAPINFOHEADER  (the dsBmih member of tagDIBSECTION)
; //    size: always 40 bytes on both x86 and x64
; //    (all fields are DWORD/LONG/WORD — no pointer members)
; // ----------------------------------------------------------
; typedef struct tagBITMAPINFOHEADER {
;     DWORD   biSize;             // +0   4 bytes  — size of this struct (40)
;     LONG    biWidth;            // +4   4 bytes  — width in pixels
;     LONG    biHeight;           // +8   4 bytes  — height (+ve = bottom-up, -ve = top-down)
;     WORD    biPlanes;           // +12  2 bytes  — must be 1
;     WORD    biBitCount;         // +14  2 bytes  — bits per pixel (1/4/8/16/24/32)
;     DWORD   biCompression;      // +16  4 bytes  — compression type (BI_RGB=0, etc.)
;     DWORD   biSizeImage;        // +20  4 bytes  — size of pixel data in bytes
;     LONG    biXPelsPerMeter;    // +24  4 bytes  — horizontal resolution
;     LONG    biYPelsPerMeter;    // +28  4 bytes  — vertical resolution
;     DWORD   biClrUsed;          // +32  4 bytes  — colours in colour table actually used
;     DWORD   biClrImportant;     // +36  4 bytes  — colours required for display
; } BITMAPINFOHEADER, *LPBITMAPINFOHEADER, *PBITMAPINFOHEADER;
; sizeof(BITMAPINFOHEADER): 40 (x86 and x64)
/**
 * GDI BITMAPINFOHEADER structure (40 bytes, identical on x86 and x64)
 */
Struct tagBITMAPINFOHEADER {
   biSize         : UInt32 ; 4
   biWidth        : Int32 ; 4
   biHeight       : Int32 ; 4
   biPlanes       : Int16 ; 2
   biBitCount     : Int16 ; 2
   biCompression  : UInt32 ; 4
   biSizeImage    : UInt32 ; 4
   biXPelsPerMeter: Int32 ; 4
   biYPelsPerMeter: Int32 ; 4
   biClrUsed      : UInt32 ; 4
   biClrImportant : UInt32 ; 4
   ; Size => ObjGetDataSize(this)
}
/**
 * Simple RGB channel structure holding three 32-bit unsigned values (R, G, B)
 */
Struct stRGB {
   R         : UInt32
   G         : UInt32
   B         : UInt32
}
; ----------------------------------------------------------
; 3. tagDIBSECTION  (the top-level structure)
;
;  x86 memory layout (sizeof = 84):
;    +0   dsBm        BITMAP             24 bytes
;    +24  dsBmih      BITMAPINFOHEADER   40 bytes
;    +64  dsBitfields DWORD[3]           12 bytes
;    +76  dshSection  HANDLE              4 bytes
;    +80  dsOffset    DWORD               4 bytes
;
;  x64 memory layout (sizeof = 104):
;    +0   dsBm        BITMAP             32 bytes
;    +32  dsBmih      BITMAPINFOHEADER   40 bytes
;    +72  dsBitfields DWORD[3]           12 bytes
;    +84  dshSection  HANDLE              8 bytes
;    +92  dsOffset    DWORD               4 bytes
;         (4 bytes trailing pad)
; ----------------------------------------------------------
/**
 * GDI DIBSECTION structure combining BITMAP, BITMAPINFOHEADER, color masks, section handle and offset
 */
Struct tagDIBSECTION {
   dsBm       : tagBITMAP
   dsBmih     : tagBITMAPINFOHEADER
   dsBitfields: stRGB
   dshSection : IntPtr
   dsOffset   : UInt32
   ; Size => ObjGetDataSize(this)
}

/**
 * Integer 2D point structure with Init helper and Int32 X/Y fields
 */
Struct stPointI {
   /**
    * Initialize the point coordinates
    * @param X X coordinate (default: 0)
    * @param Y Y coordinate (default: 0)
    */
   Init(X := 0, Y := 0) {
      this.X := X
      this.Y := Y
   }
   X: Int32
   Y: Int32
}
/**
 * Floating-point 2D point structure with Init helper and Float32 X/Y fields
 */
Struct stPointF {
   /**
    * Initialize the point coordinates
    * @param X X coordinate (default: 0)
    * @param Y Y coordinate (default: 0)
    */
   Init(X := 0, Y := 0) {
      this.X := X
      this.Y := Y
   }
   X: Float32
   Y: Float32
}
/**
 * MONITORINFOEX structure for use with GetMonitorInfo, including the monitor name string
 */
Struct stMONITORINFOEX {
   cbSize   : Int32 := ObjGetDataSize(this)
   rcMonitor: stRECTI
   rcWork   : stRECTI
   dwFlags  : Int32
   _name    : 64
   /**
    * Return the monitor device name as a string from the raw _name field
    */
   name => StrGet(this._name, 64)
}