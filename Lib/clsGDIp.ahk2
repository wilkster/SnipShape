    * @returns {Integer} GDI+ status code
    */
   Static SetPenMiterLimit(pen, miterLimit) =>   DllCall('Gdiplus\GdipSetPenMiterLimit', 'ptr', pen, 'int', miterLimit, 'uint')
   /*
  LineCapFlat          = 0,
  LineCapSquare        = 1,
  LineCapRound         = 2,
  LineCapTriangle      = 3,
  LineCapNoAnchor      = 0x10,
  LineCapSquareAnchor  = 0x11,
