    * @param TpBitmapIn 
    * @param kernel size
    * @param passses number of passes, 3 approximates a gaussian filter
    * @param horzOnly Set 1 non-zero if only horizontal filtering is done. Looks better on text blurring
    * @returns pBitmapOut Blurred bitmap
    */

   Static BoxBlurMultiPass(TpBitmapIn, kernel, passses := 3, horzOnly := 1) {
      Static mCodeFunc := 0
