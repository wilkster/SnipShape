/************************************************************************
 * @description Bitmap Class - Contains bitmap related functions
 *              Uses both pBitmaps (GDI+) and hBitmaps (GDI)
 * @file clsBitmap.ahk2
 * @author Tom Wilkason - cobbled from GDIP and Snipper functions
 * @date 2024/04/19
 * @version 1.0.0
 ***********************************************************************/

;----------------------------------------------------------------------
; BIT Map Related Functions
;----------------------------------------------------------------------
#Requires AutoHotkey v2
#Include clsGDIp.ahk2
#Include libMisc.ahk2
Class BitMap {


   /**
    * Rotate a pBitmap in place
    * @param pBitmap bitmap to rotate/flip in place
    * @param angle +/- in 90 deg increments
    * @returns {Integer} pBitmap on sucess, 0 on failure
    */
   Static Rotate(pBitmap, angle) {
      angle := Mod(angle, 360)
      If (angle < 0)
         angle += 360

      ; Map angle to RotateFlipType
      ; 0 = RotateNoneFlipNone (no rotation)
      ; 1 = Rotate90FlipNone (90° clockwise)
      ; 2 = Rotate180FlipNone (180°)
      ; 3 = Rotate270FlipNone (270° clockwise / 90° counter-clockwise)

      rotateType := 0
      Switch angle {
         Case 0:
            rotateType := 0
         Case 90:
            rotateType := 1
         Case 180:
            rotateType := 2
         Case 270:
            rotateType := 3
         default:
            Return 0  ; Invalid angle
      }
      If (res := DllCall("gdiplus\GdipImageRotateFlip", "Ptr", pBitmap, "Int", rotateType)) {
         warning("GDI+ Error " GDIp.TranslateErrorCode(res))
         Return 0
      }
      return pBitmap
   }

   /**
    * Flip a pBitmap in place
    * @param pBitmap bitmap to flip in place
    * @param flipType 1 = flip top/bottom (vertical), 2 = flip left/right (horizontal)
    * @returns {Integer} pBitmap on sucess, 0 on failure
    */
   Static Flip(pBitmap, flipType) {
      ; Map flipType to RotateFlipType
      ; 4 = RotateNoneFlipX (flip horizontal/left-right)
      ; 6 = RotateNoneFlipY (flip vertical/top-bottom)

      rotateFlipType := 0
      Switch flipType {
         Case 1:  ; Top/Bottom (vertical flip)
            rotateFlipType := 6  ; RotateNoneFlipY
         Case 2:  ; Left/Right (horizontal flip)
            rotateFlipType := 4  ; RotateNoneFlipX
         default:
            Return 0  ; Invalid flip type
      }

      ; Perform the flip
      If (res := DllCall("gdiplus\GdipImageRotateFlip", "Ptr", pBitmap, "Int", rotateFlipType)) {
         warning("GDI+ Error " GDIp.TranslateErrorCode(res))
         return 0
      }
      Return pBitmap
   }

   /**
    * Crop an hBitmap using GDI only.
    * NOTE - this would also work for enlarging as well
    * @param {Integer} hBitmap Handle to the bitmap to crop
    * @param {Integer} X X offset
    * @param {Integer} Y Y offset
    * @param {Integer} nW New width
    * @param {Integer} nH New height
    * @param {Integer} keepBitmap 0 to discard incoming bitmap when done
    * @returns {Integer} hBitmap handle to the new cropped bitmap
    */
   Static CropHBITMAP(hBitmap, X, Y, nW, nH, keepBitmap := 0) {

      hCopy    := GDI.CopyImage(hBitmap) ;; Don't touch the current bitmap
      hdcSrc   := GDI.CreateCompatibleDC(0)
      hdcClone := GDI.CreateCompatibleDC(0)
      hClone   := GDI.CreateDIBSection(nW, nH, hdcClone)
      obmSrc   := GDI.SelectObject(hdcSrc, hCopy)
      obmClone := GDI.SelectObject(hdcClone, hClone)

      GDI.BitBlt(hdcClone, 0, 0, nW, nH, hdcSrc, X, Y)
      ; clean up, user has to handle the target bitmap
      GDI.SelectObject(hdcSrc, obmSrc)
      GDI.SelectObject(hdcClone, obmClone)

      GDI.DeleteDC(hdcSrc)
      GDI.DeleteDC(hdcClone)
      GDI.DeleteObject(hCopy)
      If NOT keepBitmap
         GDI.DeleteObject(hBitmap)
      ; User needs to delete object

      Return hClone
   }

   /**
    * Slice an hBitmap using GDI only.
    * Extends w/h depending on which is larger.
    * Input coordinates will span picture one X or Y.
    * @param {Integer} hBitmap Handle to the bitmap to slice
    * @param {Integer} nX X offset (snip border offset)
    * @param {Integer} nY Y offset (snip border offset)
    * @param {Integer} nW New width
    * @param {Integer} nH New height
    * @param {Integer} keepBitmap 0 to discard incoming bitmap when done
    * @returns {Integer} hBitmap handle to the new sliced bitmap
    */
   Static SliceHBITMAP(hBitmap, nX, nY, nW, nH, keepBitmap := 0) {
      GDI.GetHBitmapDimensions(hBitmap, &ogW:=0, &ogH:=0)
      ; Determine slice based on orientation

      hCopy := GDI.CopyImage(hBitmap) ;; Don't touch the current bitmap
      hdcSrc   := GDI.CreateCompatibleDC(0)
      hdcClone := GDI.CreateCompatibleDC(0)

      obmSrc   := GDI.SelectObject(hdcSrc, hCopy) ; hBitmap
      hClone   := GDI.CreateDIBSection(ogW - (ogW = nW ? 0 : nW), ogH - (ogH = nH ? 0 : nH), hdcClone)
      obmClone := GDI.SelectObject(hdcClone, hClone)
      ; DestDC, Dest X, Dest Y, Dest Width, Dest Height, srcDC, Source X, Source Y
      If (ogH = nH) {
         ; Remove inner vertical section
         GDI.BitBlt(hdcClone, 0, 0, nX, ogH, hdcSrc) ;left
         GDI.BitBlt(hdcClone, nX, nY, ogW - nW - nX, ogH, hdcSrc, nX + nW, 0) ;Vertical
      } Else {
         ; Remove inner horizontal section
         GDI.BitBlt(hdcClone, 0, 0, ogW, nY, hdcSrc) ; top
         GDI.BitBlt(hdcClone, nX, nY, ogW, ogH - nH - nY, hdcSrc, 0, nY + nH) ; Horizontal
      }
      ; clean up, user has to handle the target bitmap
      GDI.SelectObject(hdcSrc, obmSrc)
      GDI.SelectObject(hdcClone, obmClone)

      GDI.DeleteDC(hdcSrc)
      GDI.DeleteDC(hdcClone)
      GDI.DeleteObject(hCopy)
      If NOT keepBitmap
         GDI.DeleteObject(hBitmap)

      Return hClone
   }

   /**
    * Extend an hBitmap externally using GDI only, adding a border of background color.
    * @param {Integer} hBitmap Handle to the bitmap to extend
    * @param {Integer} bgColor Background color to use for fill
    * @param {Integer} l Amount to expand to the left (or 0)
    * @param {Integer} t Amount to expand to the top (or 0)
    * @param {Integer} r Amount to expand to the right (or 0)
    * @param {Integer} b Amount to expand to the bottom (or 0)
    * @param {Integer} keepBitmap 0 to discard incoming bitmap when done
    * @returns {Integer} hBitmap handle to the new extended bitmap
    */
   Static ExtendBITMAP(hBitmap, bgColor, l, t, r, b, keepBitmap := 0) {
      GDI.GetHBitmapDimensions(hBitmap, &ogW:=0, &ogH:=0)
      hCopy := GDI.CopyImage(hBitmap) ; Don't touch the current bitmap

      ; Create the larger DIB
      hdcSrc   := GDI.CreateCompatibleDC(0)
      hdcClone := GDI.CreateCompatibleDC(0)
      ; Gets strange after here, visual bitmap may lose some background
      obmSrc   := GDI.SelectObject(hdcSrc, hCopy)
      hClone   := GDI.CreateDIBSection(ogW + l + r, ogH + t + b, hdcClone)
      obmClone := GDI.SelectObject(hdcClone, hClone)

      ; Fill with background color first since we overwrite part of it
      G := GDIp.GraphicsFromHDC(hdcClone)
      GDIp.GraphicsClear(G, (0xFF000000 | bgColor))
      GDIp.DeleteGraphics(G)

      ; Overwrite the original area with the original bitmap
      GDI.BitBlt(hdcClone, l, t, ogW, ogH, hdcSrc)

      ; clean up, user has to handle the target bitmap
      GDI.SelectObject(hdcSrc, obmSrc)
      GDI.SelectObject(hdcClone, obmClone)

      GDI.DeleteDC(hdcSrc)
      GDI.DeleteDC(hdcClone)

      GDI.DeleteObject(hCopy)
      If NOT keepBitmap
         GDI.DeleteObject(hBitmap)

      Return hClone
   }

   /**
    * Expand an hBitmap internally using GDI only, inserting a gap filled with background color.
    * Extends w/h depending on which is larger.
    * Input coordinates will span picture one X or Y.
    * @param {Integer} hBitmap Handle to the bitmap to expand
    * @param {Integer} bgColor Background color to use for fill
    * @param {Integer} l Start of insert point left (or 0)
    * @param {Integer} t Start of insert point top (or 0)
    * @param {Integer} r End of insert point right (or 0)
    * @param {Integer} b End of insert point bottom (or 0)
    * @param {Integer} keepBitmap 0 to discard incoming bitmap when done
    * @returns {Integer} hBitmap handle to the new expanded bitmap
    */
   Static ExpandBITMAP(hBitmap, bgColor, l, t, r, b, keepBitmap := 0) {
      GDI.GetHBitmapDimensions(hBitmap, &ogW:=0, &ogH:=0)
      hCopy := GDI.CopyImage(hBitmap) ; Don't touch the current bitmap

      ; Create the larger DIB
      w := abs(r-l), h := abs(b-t)
      hdcSrc   := GDI.CreateCompatibleDC(0)
      hdcClone := GDI.CreateCompatibleDC(0)
      ; Gets strange after here, visual bitmap may lose some background
      obmSrc   := GDI.SelectObject(hdcSrc, hCopy)
      hClone   := GDI.CreateDIBSection(ogW + w, ogH + h, hdcClone)
      obmClone := GDI.SelectObject(hdcClone, hClone)

      ; Fill with background color first since we overwrite part of it
      G := GDIp.GraphicsFromHDC(hdcClone)
      ; GDIp.GraphicsClear(G, (0xFF000000 | 0xFF00FF))
      GDIp.GraphicsClear(G, (0xFF000000 | bgColor))
      GDIp.DeleteGraphics(G)
      ; Two step copy leaving a gap
      If (t = 0 AND b=0) {
         ; Vertical
         GDI.BitBlt(hdcClone, 0, 0, l, ogH, hdcSrc) ; left hand piece
         GDI.BitBlt(hdcClone, r , 0, ogW - w, ogH, hdcSrc, l, 0) ; right hand piece
      } Else {
         ; Horizontal
         GDI.BitBlt(hdcClone, 0, 0, ogW, t, hdcSrc) ; top piece
         GDI.BitBlt(hdcClone, 0, b , ogW, ogH - h, hdcSrc, 0, t) ; bottom piece
      }

      ; clean up, user has to handle the target bitmap
      GDI.SelectObject(hdcSrc, obmSrc)
      GDI.SelectObject(hdcClone, obmClone)

      GDI.DeleteDC(hdcSrc)
      GDI.DeleteDC(hdcClone)
      GDI.DeleteObject(hCopy)

      If NOT keepBitmap
         GDI.DeleteObject(hBitmap)

      Return hClone
   }

   /**
    * Clone an hBitmap and crop a uniform border off all sides.
    * Caller is responsible for managing the returned bitmap.
    * @param {Integer} hBitmap Handle to the source bitmap
    * @param {Integer} BW Border width in pixels to remove from each side
    * @returns {Integer} hBitmap handle to the new border-cropped bitmap
    */
   Static CropHBitmapBorder(hBitmap, BW) {
      GDI.GetHBitmapDimensions(hBitmap, &Width, &Height)
      Return this.CropHBITMAP(hBitmap, BW, BW, Width - 2 * BW, Height - 2 * BW)
   }

   /**
    * Return a pBitmap of the specified window's contents, independent of any windows above it,
    * with an optional uniform border crop applied.
    * @param {Integer} hWnd Handle to the target window
    * @param {Integer} clientOnly 1 to capture client area only
    * @param {Integer} BW Border width in pixels to crop from each side (0 = no crop)
    * @returns {Integer} pBitmap handle to the captured (and optionally cropped) bitmap
    */
   Static pBitmapCropFromHWND(hWnd, clientOnly := 1, BW := 0) {
      hBitmap := this.HBitmapFromHWND(hWnd, clientOnly)
      pBitmap := GDIp.CreateBitmapFromHBITMAP(hBitmap)
      GDI.DeleteObject(hBitmap)
      If (BW) {
         cBitmap := this.CropPBitmapBorder(pBitmap, BW) ; gdi+
         GDI.DeleteObject(hBitmap)
         GDIp.DisposeImage(pBitmap)
         Return cBitmap
      } Else {
         Return pBitmap
      }
   }

   /**
    * Return a portion of a window as an hBitmap, with an optional uniform border crop.
    * @param {Integer} hWnd Window handle
    * @param {Integer} clientOnly 1 to capture client area only
    * @param {Integer} BW Border width in pixels to crop from each side (0 = no crop)
    * @returns {Integer} hBitmap handle to the captured (and optionally cropped) bitmap
    */
   Static hBitmapCropFromHWND(hWnd, clientOnly := 1, BW := 0) {
      hBitmap := this.HBitmapFromHWND(hWnd, clientOnly)
      If (BW) {
         hBitmap := this.CropHBitmapBorder(hBitmap, BW)
      }
      Return hBitmap
   }

   /**
    * Clone a pBitmap and crop a uniform border off all sides, retaining the original pixel format.
    * Caller is responsible for managing both the passed-in and returned bitmaps.
    * @param {Integer} pBitmap Handle to the source pBitmap
    * @param {Integer} BW Border width in pixels to remove from each side
    * @returns {Integer} pBitmap handle to the new border-cropped bitmap
    */
   Static CropPBitmapBorder(pBitmap, BW) {
      ; Retain the current PixelFormat, unlike GdipCloneImage.
      DllCall("gdiplus\GdipGetImageWidth", "ptr", pBitmap, "uint*", &width := 0)
      DllCall("gdiplus\GdipGetImageHeight", "ptr", pBitmap, "uint*", &height := 0)
      DllCall("gdiplus\GdipGetImagePixelFormat", "ptr", pBitmap, "int*", &pformat := 0)
      res := DllCall("gdiplus\GdipCloneBitmapAreaI"
         , "int", BW
         , "int", BW
         , "int", width - BW * 2
         , "int", height - BW * 2
         , "int", pformat
         , "ptr", pBitmap
         , "ptr*", &pBitmapCrop := 0)
      If (res)
         warning("GDI+ Error " GDIp.TranslateErrorCode(res))
      Return pBitmapCrop
   }

   /**
    * Clone a pBitmap and crop it to the specified rectangle, retaining the original pixel format.
    * Caller is responsible for managing both the passed-in and returned bitmaps, and for boundary checking.
    * @param {Integer} pBitmap Handle to the source pBitmap
    * @param {Integer} X Left edge of the crop rectangle
    * @param {Integer} Y Top edge of the crop rectangle
    * @param {Integer} W Width of the crop rectangle
    * @param {Integer} H Height of the crop rectangle
    * @returns {Integer} pBitmap handle to the new cropped bitmap
    */
   Static CropPBitmap(pBitmap, X, Y, W, H) {
      ; Retain the current PixelFormat, unlike GdipCloneImage.
      DllCall("gdiplus\GdipGetImageWidth", "ptr", pBitmap, "uint*", &width := 0)
      DllCall("gdiplus\GdipGetImageHeight", "ptr", pBitmap, "uint*", &height := 0)
      DllCall("gdiplus\GdipGetImagePixelFormat", "ptr", pBitmap, "int*", &pformat := 0)
      res := DllCall("gdiplus\GdipCloneBitmapAreaI"
         , "int", X
         , "int", Y
         , "int", W
         , "int", H
         , "int", pformat ;139273
         , "ptr", pBitmap
         , "ptr*", &pBitmapCrop := 0)
      If (res)
         warning("GDI+ Error " GDIp.TranslateErrorCode(res))

      Return pBitmapCrop
   }

   /**
    * Capture a window's screen contents as an hBitmap.
    * Uses WinGetPosEx for top-level windows to exclude extended borders, or WinGetPos for child windows.
    * @param {Integer} hWnd Handle to the target window
    * @param {Integer} NoExtendedBorder 1 to exclude the extended (DWM) border (default), 0 to include it
    * @returns {Integer} hBitmap handle to the captured bitmap, or 0 on failure
    */
   Static HBitmapFromHWND(hWnd, NoExtendedBorder := 1) {
      If ((GetParent(hWnd) != hWnd) OR NOT NoExtendedBorder)
         WinGetPos(&X := 0, &Y := 0, &W := 0, &H := 0, hWnd)
      Else
         WinGetPosEx(&X := 0, &Y := 0, &W := 0, &H := 0, hWnd)
      If (W > 0 AND H > 0) {
         Area := { X: X, Y: Y, X2: X + W, Y2: Y = H, W: W, H: H }
         Return this.HBitmapFromScreen(Area)
      } Else {
         warning("Failed to retrive window position for " hex(hWnd))
         Return 0
      }
   }

   /**
    * Capture a window's contents as an hBitmap using PrintWindow.
    * Works for windows with DPI support. Falls back to HBitmapFromScreen for
    * legacy windows where the window DPI differs from the monitor DPI.
    * @param {Integer} hWnd Handle to the target window
    * @param {Integer} skipBorders 1 to use WinGetPosEx (exclude extended borders)
    * @returns {Integer} hBitmap handle to the captured bitmap, or 0 on failure
    */
   Static HBitmapFromHWNDPW(hWnd, skipBorders := 1) {
      Static PW_RENDERFULLCONTENT := 0x2
      ; If (skipBorders = 1)
      ;    WinGetPosEx(&X, &Y, &W, &H, hWnd)
      ; Else
      ;    WinGetPos(&X, &Y, &W, &H, hWnd)

      hWndDpi := WinDPI(hWnd)
      monDpi := MonDPIunderWindow(hWnd)
      ; BUG - Legacy windows use the clunkly HBitmapFromScreen method
      ;       Since PrintWindow and PW_RENDERFULLCONTENT won't support transform scaling
      WinGetPosEx(&X, &Y, &W, &H, hWnd)
      If (hWndDpi != monDpi) {
         If (W > 0 AND H > 0) {
            Area := { X: X, Y: Y, X2: X + W, Y2: Y = H, W: W, H: H }
            debug("DPI Different, using HBitmapFromScreen " hWndDpi " vs " monDpi)
            Return this.HBitmapFromScreen(Area)
         } Else {
            warning("Failed to retrive window position for " hex(hWnd))
            Return 0
         }
      }
      ; Try Printwindow Method
      ; WinGetPosEx(&X, &Y, &W, &H, hWnd)
      ; WinGetPos(&X, &Y, &W, &H, hWnd)
      hdc     := GDI.GetDC(hWnd)
      hdcMem  := GDI.CreateCompatibleDC(hdc) ; or 0 both fail
      hBitmap := GDI.CreateDIBSection(W, H, hdcMem)
      obm     := GDI.SelectObject(hdcMem, hBitmap)
      DllCall("PatBlt", "Ptr", hdcMem, "Int", 0, "Int", 0, "Int", W, "Int", H, "UInt", 0x00F00021) ; PATCOPY (white)

      ; If the flag  = 0x1 it seems the picture but not the shapes get copied
      ; success := this.PrintWindow(hWnd, hdcMem, PW_RENDERFULLCONTENT | (skipBorders & 0x1))
      ; PW_CLIENTONLY = 1, excludes the caption
      ; BUG - Legacy apps are shift to the right by 11 pixels and down by a 1/2 pixels
      success := this.PrintWindow(hWnd, hdcMem, PW_RENDERFULLCONTENT)
      GDI.SelectObject(hdcMem, obm)
      GDI.DeleteDC(hdcMem)
      GDI.ReleaseDC(hdc)
      If ( NOT success) {
         MsgBox("Failed to Print Window Properly")
         Return 0
      }
      Return hBitmap
   }

   /**
    * Copy the contents of a window into a specified HDC using the PrintWindow API.
    * @param {Integer} hwnd Handle to the window to print
    * @param {Integer} hdc Handle to the destination device context
    * @param {Integer} Flags PrintWindow flags (default: 2 = PW_RENDERFULLCONTENT)
    * @returns {Integer} Non-zero on success, 0 on failure
    */
   Static PrintWindow(hwnd, hdc, Flags := 2) => DllCall("User32\PrintWindow", "Ptr", hwnd, "Ptr", hdc, "uint", Flags)

   ;====================== BACKGROUND STUFF ===========================
   /**
    * Return the most common rgb value from a pBitmap, typically the background.
    * @param {Integer} pBitmap Handle to the source pBitmap
    * @returns {Integer} RGB color value as R<<16 | G<<8 | B without alpha channel
    * NOTE, could be adpted to use an hBitmap as well
    */
   Static GetBackgroundColor(uBitmap) {
      /*
      This method uses less memory by hashing the pixels and using a smaller histogram,
      hash size is dynamic based on image size
      #include <stdint.h>
      #include <stdlib.h>
      #include <string.h>

      uint32_t find_background_color_hash(const uint8_t* pixels, int width, int height, int stride)
      {
         if (width <= 0 || height <= 0)
            return 0xFF000000;

         // Scale step to image size — larger images need less density
         const int step = (width > 512 || height > 512) ? 4 :
                           (width > 64  || height > 64)  ? 2 : 1;

         // Estimate sampled pixel count and pick smallest table that keeps load < 25%
         // (4x slots per sampled pixel avoids collisions without over-allocating)
         const uint32_t sampled = (uint32_t)((width / step) * (height / step));
         uint32_t TABLE_BITS = 14;                          // minimum: 16K slots, 256KB
         while (TABLE_BITS < 20 && (1u << TABLE_BITS) < sampled * 4)
            TABLE_BITS++;                                  // maximum: 1M slots, 16MB

         const uint32_t TABLE_SIZE = 1u << TABLE_BITS;
         const uint32_t TABLE_MASK = TABLE_SIZE - 1;

         uint32_t* table = (uint32_t*)calloc(TABLE_SIZE * 2, sizeof(uint32_t));
         if (!table) return 0xFF000000;

         const uint8_t* row = pixels;
         for (int y = 0; y < height; y += step) {
            const uint8_t* p = row;
            for (int x = 0; x < width; x += step) {
                  uint32_t b = p[0];
                  uint32_t g = p[1];
                  uint32_t r = p[2];
                  uint32_t a = p[3];
                  p += 4 * step;
                  if (a == 0)
                     continue;
                  uint32_t rgb = (r << 16) | (g << 8) | b;
                  uint32_t h = (rgb * 2654435761u) >> (32 - TABLE_BITS);
                  uint32_t probe_dist = 0;
                  for (;;) {
                     uint32_t idx   = (h & TABLE_MASK) * 2;
                     uint32_t count = table[idx + 1];
                     if (count == 0) {
                        table[idx + 0] = rgb;
                        table[idx + 1] = 1;
                        break;
                     }
                     if (table[idx + 0] == rgb) {
                        table[idx + 1] = count + 1;
                        break;
                     }
                     uint32_t existing_home = (table[idx + 0] * 2654435761u) >> (32 - TABLE_BITS);
                     uint32_t existing_dist = (h - existing_home) & TABLE_MASK;
                     if (existing_dist < probe_dist) {
                        uint32_t tmp_rgb   = table[idx + 0];
                        uint32_t tmp_count = table[idx + 1];
                        table[idx + 0] = rgb;
                        table[idx + 1] = 1;
                        rgb        = tmp_rgb;
                        count      = tmp_count;
                        probe_dist = existing_dist;
                     }
                     h++;
                     probe_dist++;
                     if (probe_dist >= TABLE_SIZE) {
                        uint32_t min_idx   = 0;
                        uint32_t min_count = UINT32_MAX;
                        for (uint32_t j = 0; j < TABLE_SIZE; j++) {
                              if (table[j * 2 + 1] < min_count) {
                                 min_count = table[j * 2 + 1];
                                 min_idx   = j;
                              }
                        }
                        table[min_idx * 2 + 0] = rgb;
                        table[min_idx * 2 + 1] = 1;
                        break;
                     }
                  }
            }
            row += stride * step;
         }

         uint32_t best_color = 0;
         uint32_t best_count = 0;
         for (uint32_t i = 0; i < TABLE_SIZE; i++) {
            uint32_t count = table[i * 2 + 1];
            if (count > best_count) {
                  best_count = count;
                  best_color = table[i * 2 + 0];
            }
         }

         free(table);
         return best_color;
      }

      */

      Static mCodeFunc := 0
      If (mCodeFunc = 0) {
         ; Using MFC.exe to compile -m64 -O3 -fPIC -fno-stack-protector -fno-plt -fno-asynchronous-unwind-tables
         If (A_PtrSize = 8) {
         x64 := "
         (
         QVdBVkFVQVRVV1ZTSIPsSEiJjCSQAAAAiZQkmAAAAESJhCSgAAAAhdIPjtoCAABFhcAPjtECAACBvCSYAAAAAAIAAEWJzn9IgbwkoAAAAAACAAB/O4O8JJgAAABAD4+uAgAAg7wkoAAAAEAPj6ACAACLhCSYAAAARInCuwEAAABIx0Qk
         IAQAAAC9AQAAAOsni4QkmAAAALsEAAAAvQQAAACLlCSgAAAASMdEJCAQAAAAwfgCwfoCD6/CweACPQBAAAAPhnMCAAA9AIAAAA+GlwIAAD0AAAEAD4aZAgAAPQAAAgAPhpsCAAA9AAAEAA+GaQIAAEG9EwAAAL8AAAgAPQAACAAPhjwC
         AAC+//8PAL8AABAAuQAAIABBvRQAAAC6BAAAAOgAAAAASYnESIXAD4TUAQAAQQ+v3sdEJCwAAAAAuSAAAABEKelIY8NIiUQkOIn4SIlEJDAPH4QAAAAAAEyLrCSQAAAARTH26xkPHwBBAe5MA2wkIEQ5tCSYAAAAD44aAQAAQYB9AwB0
         40UPtlUCQQ+2RQFFMcDB4AhBweIQQQnCQQ+2RQBBCcJBadKxeTee0+oPHwBBidFBIfFFAclBjUEBS40cjE2NHIRBiwOFwA+EoAAAAESLC0U50Q+ErAAAAEFpwbF5N57T6EGJx4nQRCn4IfBBOcB2JESNQAFEiRODwgFBxwMBAAAARDnH
         dh1FicrroWYPH4QAAAAAAEGDwAGDwgFBOfhyjEWJ0UyLXCQwMcBBuP////9FMdKQQYtUxAREOcJzBkGJ0EGJwkiDwAFJOcN150ONBBJFiQyEjUABQccEhAEAAADp//7//w8fgAAAAABEiRNBxwMBAAAA6en+//9mDx+EAAAAAACDwAFB
         iQPp1f7//w8fRAAASItEJDgBbCQsSAGEJJAAAACLRCQsOYQkoAAAAA+Pnv7//41X/0yJ4DHJRTHtTY1E1AhmDx9EAACLUAQ5ynYFRIsoidFIg8AISTnAdetMieHoAAAAAEiDxEhEiehbXl9dQVxBXUFeQV/DQb0AAAD/6+SLhCSYAAAA
         uwIAAAC9AgAAAIuUJKAAAABIx0QkIAgAAADR+NH66Xz9//9BvQ4AAAC/AEAAALgCAAAARInpicbT5kiJ8Y13/+nC/f//Qb0SAAAAvwAABADr3EG9DwAAAL8AgAAA689BvRAAAAC/AAABAOvCQb0RAAAAvwAAAgDrtZCQkJCQkJCQkJCQ
         kJCQkA==|msvcrt:calloc:293:4|msvcrt:free:753:4
         )"
            mCodeFunc := Bitmap.GetMcodePtr(x64)
         } Else {
            MsgBox("32 bit Not Implemented")
            return
         }
      }
      ; get dimensions and reference to first pixel in memory (iScan)
      If (mCodeFunc) {
         r := 0
         Switch BitMap.getImageType(uBitmap) {
            Case "pBitmap":
               GDIp.GetImageDimensions(uBitmap, &w, &h)
               ; debug("pBitmap=" NumGet(iScan,"Uint"))
               GDIp.LockBits(uBitmap, 0, 0, w, h, &stride, &iScan, &iData, 1, 0x26200A) ; 1 is read only
               ; FindBackgroundColor(const uint8_t *pixels, int width, int height, int stride) {
               r := DllCall(mCodeFunc, "UPtr", iScan, "uInt", w, "Int", h, "uInt", stride)
               GDIp.UnlockBits(uBitmap, &iData)
            Case "hBitmap":
               res := BitMap.GetDIBSectionInfo(uBitmap)
               r := DllCall(mCodeFunc, "UPtr", res.ptr, "uInt", res.w, "Int", res.h, "uInt", res.stride)
            Default:
         }

         Return r
      } Else {
         elog("Failed to compile MCode")
         Return 0
      }
   }

   ;====================== DONE BACKGROUND STUFF ===========================

   /**
    * Capture a rectangular screen area as an hBitmap using GDI BitBlt with CAPTUREBLT.
    * @param {Object} Area Object with X, Y, W, H properties defining the screen region
    * @returns {Integer} hBitmap handle to the captured screen bitmap
    */
   Static HBitmapFromScreen(Area) {
      hdcScreen := GDI.GetDC(0) ; 0 makes no difference than GetDesktopWindow
      ; Using either a DIB or Compatible bitmap is about the same, 60ms on fast computer
      hdcMem := GDI.CreateCompatibleDC(hdcScreen)
      hBitmap := GDI.CreateDIBSection(Area.W, Area.H, hdcMem)
      ogBM := GDI.SelectObject(hdcMem, hBitmap)
      ; Copy over screen bits to memdc (all of the time is here) (get any layers as well)
      ; 4k monitor takes 60ms which is really slow
      ; 70 ms on orka
      GDI.BitBlt(hdcMem, 0, 0, Area.W, Area.H, hdcScreen, Area.X, Area.Y, 0x40CC0020) ; CAPTUREBLT | SRCCOPY
      GDI.SelectObject(hdcMem, ogBM)
      GDI.ReleaseDC(hdcScreen)
      GDI.DeleteDC(hdcMem)
      Return hBitmap
   }

   /**
    * Capture a screen area as an hBitmap and paint it into a layered window.
    * Optionally captures from the active window instead of the screen region.
    * @param {Object} Area Object with X, Y, W, H properties defining the region
    * @param {Integer} hWnd Handle to the layered window to update
    * @param {Integer} getWin 0 to capture from screen (default), 1 to capture from the active window
    */
   Static OverlayToLayeredWindow(Area, hWnd, getWin := 0) {
      ;HBitmapToLayeredWindow Grab the Screen
      hBitmap := getWin ? this.HBitmapFromHWND(WinActive("A"), 0) : this.HBitmapFromScreen(Area)
      ; Create a new DC based on hBitmap and display it
      hdcMem := GDI.CreateCompatibleDC()
      ogBM := GDI.SelectObject(hdcMem, hBitmap)
      GDI.UpdateLayeredWindow(hWnd, hdcMem, Area.X, Area.Y, Area.W, Area.H)
      ; clean up
      GDI.SelectObject(hdcMem, ogBM)
      GDI.DeleteDC(hdcMem)
      ; Release the hBitmap as well
      GDI.DeleteObject(hBitmap)
      Return
   }

   /**
    * Save a pBitmap to a file or return it as a Base64-encoded string.
    * Supports BMP, DIB, RLE, JPG/JPEG/JPE/JFIF, GIF, TIF/TIFF, and PNG formats.
    * @param {Integer} pBitmap Handle to the source pBitmap
    * @param {String} sOutput Destination file path including extension
    * @param {Integer} Quality JPEG quality level 0–100 (default: 75)
    * @param {Integer} toBase64 1 to return a Base64 string instead of writing a file (default: 0)
    * @returns {Integer|String} 0 on success, a Base64 string when toBase64=1,
    *                           or a negative error code on failure:
    *                           -1 unsupported extension, -2 no encoders found,
    *                           -3 codec not found, -5 save failed,
    *                           -6/-7 Base64 encoding error
    */
   Static SaveBitmapToFile(pBitmap, sOutput, Quality := 75, toBase64 := 0) {
      _p := 0

      SplitPath sOutput, , , &Extension
      If !RegExMatch(Extension, "^(?i:BMP|DIB|RLE|JPG|JPEG|JPE|JFIF|GIF|TIF|TIFF|PNG)$")
         Return -1

      Extension := "." Extension
      DllCall("gdiplus\GdipGetImageEncodersSize", "uint*", &nCount := 0, "uint*", &nSize := 0)
      ci := Buffer(nSize)
      DllCall("gdiplus\GdipGetImageEncoders", "uint", nCount, "uint", nSize, "Ptr", ci.ptr)
      If !(nCount && nSize)
         Return -2

      Static IsUnicode := StrLen(Chr(0xFFFF))
      If (IsUnicode) {
         StrGet_Name := "StrGet"
         Loop nCount {
            sString := %StrGet_Name%(NumGet(ci, (idx := (48 + 7 * A_PtrSize) * (A_Index - 1)) + 32 + 3 * A_PtrSize, "Ptr"), "UTF-16")
            If !InStr(sString, "*" Extension)
               Continue

            pCodec := ci.ptr + idx
            Break
         }
      } Else {
         Loop nCount {
            Location := NumGet(ci, 76 * (A_Index - 1) + 44, "Ptr")
            nSize := DllCall("Kernel32\WideCharToMultiByte", "uint", 0, "uint", 0, "uint", Location, "int", -1, "uint", 0, "int", 0, "uint", 0, "uint", 0)
            sString := Buffer(nSize)
            DllCall("Kernel32\WideCharToMultiByte", "uint", 0, "uint", 0, "uint", Location, "int", -1, "str", sString, "int", nSize, "uint", 0, "uint", 0)
            If !InStr(sString, "*" Extension)
               Continue

            pCodec := ci.ptr + 76 * (A_Index - 1)
            Break
         }
      }

      If !pCodec
         Return -3

      If (Quality != 75) {
         Quality := (Quality < 0) ? 0 : (Quality > 100) ? 100 : Quality
         If (Quality > 90 && toBase64 = 1)
            Quality := 90

         If RegExMatch(Extension, "^\.(?i:JPG|JPEG|JPE|JFIF)$") {
            DllCall("gdiplus\GdipGetEncoderParameterListSize", "Ptr", pBitmap, "Ptr", pCodec, "uint*", &nSize)
            EncoderParameters := Buffer(nSize, 0)
            DllCall("gdiplus\GdipGetEncoderParameterList", "Ptr", pBitmap, "Ptr", pCodec, "uint", nSize, "Ptr", EncoderParameters.ptr)
            nCount := NumGet(EncoderParameters, "UInt")
            Loop nCount {
               elem := (24 + A_PtrSize) * (A_Index - 1) + 4 + (pad := (A_PtrSize = 8) ? 4 : 0)
               If (NumGet(EncoderParameters, elem + 16, "UInt") = 1) && (NumGet(EncoderParameters, elem + 20, "UInt") = 6) {
                  _p := elem + EncoderParameters.ptr - pad - 4
                  NumPut("UInt", Quality, NumGet(NumPut("UInt", 4, NumPut("Ptr", 1, _p + 0) + 20), "Ptr"))
                  Break
               }
            }
         }
      }

      If (toBase64 = 1) {
         ; part of the function extracted from ImagePut by iseahound
         ; https://www.autohotkey.com/boards/viewtopic.php?f=6&t=76301&sid=bfb7c648736849c3c53f08ea6b0b1309
         DllCall("ole32\CreateStreamOnHGlobal", "Ptr", 0, "int", true, "UPtr*", &pStream := 0)
         _E := DllCall("gdiplus\GdipSaveImageToStream", "Ptr", pBitmap, "Ptr", pStream, "Ptr", pCodec, "uint", _p)
         If _E
            Return -6

         DllCall("ole32\GetHGlobalFromStream", "Ptr", pStream, "uint*", &hData)
         pData := DllCall("GlobalLock", "Ptr", hData, "Ptr")
         nSize := DllCall("GlobalSize", "uint", pData)

         bin := Buffer(nSize, 0)
         DllCall("RtlMoveMemory", "Ptr", bin.ptr, "Ptr", pData, "Ptr", nSize)
         DllCall("GlobalUnlock", "Ptr", hData)
         ObjRelease(pStream)
         DllCall("GlobalFree", "Ptr", hData)

         ; Using CryptBinaryToStringA saves about 2MB in memory.
         DllCall("Crypt32.dll\CryptBinaryToStringA", "Ptr", bin.ptr, "uint", nSize, "uint", 0x40000001, "Ptr", 0, "uint*", &base64Length := 0)
         base64 := Buffer(base64Length, 0)
         _E := DllCall("Crypt32.dll\CryptBinaryToStringA", "Ptr", bin.ptr, "uint", nSize, "uint", 0x40000001, "Ptr", &base64, "uint*", base64Length)
         If !_E
            Return -7

         bin := Buffer(0)
         Return StrGet(base64, base64Length, "CP0")
      }

      _E := DllCall("gdiplus\GdipSaveImageToFile", "Ptr", pBitmap, "WStr", sOutput, "Ptr", pCodec, "uint", _p)
      Return _E ? -5 : 0
   }

   /**
    * Scale a pBitmap to a new size using highest-quality GDI+ settings (HighQualityBicubic).
    * The input pBitmap is disposed after scaling.
    * Based on iseahound's ImagePut library.
    * @param {Integer} TpBitmap Handle to the source pBitmap (disposed on return)
    * @param {Float|Array} scale Numeric scale factor (e.g. 0.5, 2.0), or a two-element array
    *                            [width, height] where one element may be 0 to compute proportionally
    * @param {Integer} direction 0 = scale always (default), >0 = upscale only, <0 = downscale only
    * @returns {Integer} pBitmap handle to the new scaled bitmap, or the original if no scaling occurred
    */
   Static BitmapScale(TpBitmap, scale, direction := 0) {
      If not (IsObject(scale) && ((scale[1] ~= "^\d+$") || (scale[2] ~= "^\d+$")) || (scale ~= "^\d+(\.\d+)?$"))
         Throw Error("Invalid scale.")

      ; Get Bitmap width, height, and format.
      DllCall("gdiplus\GdipGetImageWidth", "ptr", TpBitmap, "uint*", &width := 0)
      DllCall("gdiplus\GdipGetImageHeight", "ptr", TpBitmap, "uint*", &height := 0)
      DllCall("gdiplus\GdipGetImagePixelFormat", "ptr", TpBitmap, "int*", &pformat := 0)

      If IsObject(scale) {
         safe_w := (scale[1] ~= "^\d+$") ? scale[1] : Round(width / height * scale[2])
         safe_h := (scale[2] ~= "^\d+$") ? scale[2] : Round(height / width * scale[1])
      } Else {
         safe_w := Ceil(width * scale)
         safe_h := Ceil(height * scale)
      }

      ; Avoid drawing if no changes detected.
      If (safe_w = width && safe_h = height)
         Return TpBitmap

      ; Force upscaling.
      If (direction > 0 and (safe_w < width && safe_h < height))
         Return TpBitmap

      ; Force downscaling.
      If (direction < 0 and (safe_w > width && safe_h > height))
         Return TpBitmap

      ; Create a new bitmap and get the graphics context.
      DllCall("gdiplus\GdipCreateBitmapFromScan0"
         , "int", safe_w, "int", safe_h, "int", 0, "int", pformat, "ptr", 0, "ptr*", &pBitmapScale := 0)
      DllCall("gdiplus\GdipGetImageGraphicsContext", "ptr", pBitmapScale, "ptr*", &pGraphics := 0)

      ; Set settings in graphics context.
      ; https://photosauce.net/blog/post/image-scaling-with-gdi-part-3-drawimage-and-the-settings-that-affect-it
      DllCall("gdiplus\GdipSetPixelOffsetMode", "Ptr", pGraphics, "int", 2) ; Half pixel offset.
      DllCall("gdiplus\GdipSetCompositingMode", "Ptr", pGraphics, "int", 1) ; Overwrite/SourceCopy.
      DllCall("gdiplus\GdipSetInterpolationMode", "Ptr", pGraphics, "int", 7) ; HighQualityBicubic

      ; Draw Image.
      DllCall("gdiplus\GdipCreateImageAttributes", "ptr*", &ImageAttr := 0)
      DllCall("gdiplus\GdipSetImageAttributesWrapMode", "ptr", ImageAttr, "int", 3, "uint", 0, "int", 0) ; WrapModeTileFlipXY
      DllCall("gdiplus\GdipDrawImageRectRectI"
         , "ptr", pGraphics
         , "ptr", TpBitmap
         , "int", 0, "int", 0, "int", safe_w, "int", safe_h ; destination rectangle
         , "int", 0, "int", 0, "int", width, "int", height ; source rectangle
         , "int", 2
         , "ptr", ImageAttr
         , "ptr", 0
         , "ptr", 0)
      DllCall("gdiplus\GdipDisposeImageAttributes", "ptr", ImageAttr)

      ; Clean up the graphics context.
      DllCall("gdiplus\GdipDeleteGraphics", "ptr", pGraphics)
      DllCall("gdiplus\GdipDisposeImage", "ptr", TpBitmap)

      Return pBitmapScale
   }

   ;----------------------------------------------------------------------
   ; by Marius Șucan GDIp Library
   ; uses compiled C code below
   ;----------------------------------------------------------------------
   /**
    * Pixelate a pBitmap using compiled machine code for performance.
    * The input pBitmap is disposed after pixelation.
    * Based on Marius Șucan's GDIp Library.
    * @param {Integer} TpBitmapIn Handle to the source pBitmap (disposed on return)
    * @param {Integer} BlockSize Pixel block size; smaller blocks produce less pixelation
    * @returns {Integer} pBitmap handle to the new pixelated bitmap, or a negative error code:
    *                    -1 = dimension mismatch, -2 = BlockSize exceeds image dimensions,
    *                    -3 = failed to lock bits
    */
   /*
   C/C++ Function by Tic and fixed by Fincs;
   https://autohotkey.com/board/topic/29449-gdi-standard-library-145-by-tic/page-55

   int __stdcall Gdip_PixelateBitmap(unsigned char * sBitmap, unsigned char * dBitmap, int w, int h, int Stride, int Size)
   {
      int sA, sR, sG, sB, rw, rh, o;

      for (int y1 = 0; y1 < h/Size; ++y1)
      {
         for (int x1 = 0; x1 < w/Size; ++x1)
         {
               sA = sR = sG = sB = 0;
               for (int y2 = 0; y2 < Size; ++y2)
               {
                  for (int x2 = 0; x2 < Size; ++x2)
                  {
                     o = 4*(x2+x1*Size)+Stride*(y2+y1*Size);
                     sA += sBitmap[3+o];
                     sR += sBitmap[2+o];
                     sG += sBitmap[1+o];
                     sB += sBitmap[o];
                  }
               }

               sA /= Size*Size;
               sR /= Size*Size;
               sG /= Size*Size;
               sB /= Size*Size;
               for (int y2 = 0; y2 < Size; ++y2)
               {
                  for (int x2 = 0; x2 < Size; ++x2)
                  {
                     o = 4*(x2+x1*Size)+Stride*(y2+y1*Size);
                     dBitmap[3+o] = sA;
                     dBitmap[2+o] = sR;
                     dBitmap[1+o] = sG;
                     dBitmap[o] = sB;
                  }
               }
         }

         if (w % Size != 0)
         {
               sA = sR = sG = sB = 0;
               for (int y2 = 0; y2 < Size; ++y2)
               {
                  for (int x2 = 0; x2 < w % Size; ++x2)
                  {
                     o = 4*(x2+(w/Size)*Size)+Stride*(y2+y1*Size);
                     sA += sBitmap[3+o];
                     sR += sBitmap[2+o];
                     sG += sBitmap[1+o];
                     sB += sBitmap[o];
                  }
               }

               {
               int tmp = (w % Size)*Size;
               sA = tmp ? (sA / tmp) : 0;
               sR = tmp ? (sR / tmp) : 0;
               sG = tmp ? (sG / tmp) : 0;
               sB = tmp ? (sB / tmp) : 0;
               }
               for (int y2 = 0; y2 < Size; ++y2)
               {
                  for (int x2 = 0; x2 < w % Size; ++x2)
                  {
                     o = 4*(x2+(w/Size)*Size)+Stride*(y2+y1*Size);
                     dBitmap[3+o] = sA;
                     dBitmap[2+o] = sR;
                     dBitmap[1+o] = sG;
                     dBitmap[o] = sB;
                  }
               }
         }
      }

      for (int x1 = 0; x1 < w/Size; ++x1)
      {
         sA = sR = sG = sB = 0;
         for (int y2 = 0; y2 < h % Size; ++y2)
         {
               for (int x2 = 0; x2 < Size; ++x2)
               {
                  o = 4*(x2+x1*Size)+Stride*(y2+(h/Size)*Size);
                  sA += sBitmap[3+o];
                  sR += sBitmap[2+o];
                  sG += sBitmap[1+o];
                  sB += sBitmap[o];
               }
         }

         {
         int tmp = Size*(h % Size);
         sA = tmp ? (sA / tmp) : 0;
         sR = tmp ? (sR / tmp) : 0;
         sG = tmp ? (sG / tmp) : 0;
         sB = tmp ? (sB / tmp) : 0;
         }

         for (int y2 = 0; y2 < h % Size; ++y2)
         {
               for (int x2 = 0; x2 < Size; ++x2)
               {
                  o = 4*(x2+x1*Size)+Stride*(y2+(h/Size)*Size);
                  dBitmap[3+o] = sA;
                  dBitmap[2+o] = sR;
                  dBitmap[1+o] = sG;
                  dBitmap[o] = sB;
               }
         }
      }

      sA = sR = sG = sB = 0;
      for (int y2 = 0; y2 < h % Size; ++y2)
      {
         for (int x2 = 0; x2 < w % Size; ++x2)
         {
               o = 4*(x2+(w/Size)*Size)+Stride*(y2+(h/Size)*Size);
               sA += sBitmap[3+o];
               sR += sBitmap[2+o];
               sG += sBitmap[1+o];
               sB += sBitmap[o];
         }
      }

      {
      int tmp = (w % Size)*(h % Size);
      sA = tmp ? (sA / tmp) : 0;
      sR = tmp ? (sR / tmp) : 0;
      sG = tmp ? (sG / tmp) : 0;
      sB = tmp ? (sB / tmp) : 0;
      }

      for (int y2 = 0; y2 < h % Size; ++y2)
      {
         for (int x2 = 0; x2 < w % Size; ++x2)
         {
               o = 4*(x2+(w/Size)*Size)+Stride*(y2+(h/Size)*Size);
               dBitmap[3+o] = sA;
               dBitmap[2+o] = sR;
               dBitmap[1+o] = sG;
               dBitmap[o] = sB;
         }
      }
      return 0;
   }

   */
   Static PixelateBitmap(TpBitmapIn, BlockSize) {
      Static PixelateBitmap := 0
      If (!PixelateBitmap) {
         If (A_PtrSize != 8) ; x86 machine code
            MCode_PixelateBitmap := "
         (LTrim Join
         558BEC83EC3C8B4514538B5D1C99F7FB56578BC88955EC894DD885C90F8E830200008B451099F7FB8365DC008365E000894DC88955F08945E833FF897DD4
