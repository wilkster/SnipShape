            JBBEicCLdCQQiVQkFJn3fTiDfCQUAYPe/4l0JCyD+gGJRCQEg9j/iRQkiUQkDIXAD4ThBQAAi0U4i3QkFGYP79LHRCQYAAAAAMdEJBwAAAAAD6/BiUQkCItFOMHgAolEJDSLRTiD6AGJRCRUi0U4wegCSMHgBEiJRCRYi0U4g+D8iUQk
            QEjB4AJIiUQkYI1G/4lEJHSJ8IPm/MHoAol0JERIweAESIlEJEiJ8EjB4AJIiUQkaEhjwUiJRCR4i3QkHIsEJDl0JASLVCQsD09FOIlEJDiF0g+EIAUAAItEJBCFwA+EZggAAIt0JCzHRCRQAAAAAGYP79vHRCQ8AAAAAESLfTg58A9O
            8ItEJDgPr0U4iXQkMIlEJChIY0QkGEiJRCQgZg8fhAAAAAAAi0QkOIXAD4QoAgAASItEJCBMY1wkUEUx9kUxyUiLVRBEi2QkVEUx0kUxwEmNNAOLXCRATItsJHgxyUgB8kiJtCSAAAAAi3QkOEiJ0EGD/AIPhs4BAABmLg8fhAAAAAAA
            Zg9u+WZBD27ASItEJFhmQQ9u4WYPYsdmQQ9u+mYP7+1mD2LnSI0MEGYPb/VIidBmD2zgZg9v/WYPH4QAAAAAAPMPbwBIg8AQZg9vyGYPaMJmD2DKZkQPb8FmD2nLZg/++WYPb8hmRA9hw2YPYctmD2nDZkEP/uBmD/7xZg/+6Eg5yHW8
            ZkEPfuFmD374Zg9wxFVBidtBAcFmD37wZkEPfsJBAcFmD3DHVWYPfuhBAcFmD37AZg9wxlVBAcJmD37AZg9wxVVBAcJmD37AZg9vxGYPasRBAcJmD3Dk/2ZBD37AZg9vx2YPcM7/Zg9qx2YPfsBmD2/GZg9qxkEBwGYPfsBmD2/FZg9q
            xUEBwGYPfsBmD3DF/0EBwGYPfuBmD3Dn/2YPfuEByGYPfskBwWYPfsABwUiLRCRgSAHQRDn7dGUPtjhBAfkPtngBQQH6D7Z4AkEB+A+2eAMB+UGNewFBOf9+Qg+2eARBg8MCQQH5D7Z4BUEB+g+2eAZBAfgPtngHAflFOd9+HkQPtlgI
            RQHZRA+2WAlFAdpED7ZYCg+2QAtFAdgBwUGNRgFMAeo5xg+EDAMAAEGJxkiJ0EGD/AIPhzz+//9FMdvpdP///w8fQABEi304g0QkPAGLfCQ0i0QkPAF8JFA7RCQwD4yx/f//OUQkLA+OdwIAAItEJDwPr0U4Zg/v20SLfCQUweACiUQk
            MItEJDhBD6/HiUQkKEhjRCQYSIlEJCBmDx+EAAAAAABEi2QkOEWF5A+EFwIAAExjXCQwSItEJCBFMfZFMclIi1UQi1wkREUx0kUxwEmNNANMi2wkeDHJSIm0JIAAAABIAfJIi3QkSGYPH4QAAAAAAEiJ0EWF/w+EqQEAAIN8JHQCD4Yj
            BQAAZg9u+WZBD27AZkEPbuFmD2LHZkEPbvpmD+/tZg9i50iNDBZmD2/1Zg9s4GYPb/1mLg8fhAAAAAAA8w9vAEiDwBBmD2/IZg9owmYPYMpmRA9vwWYPactmD/75Zg9vyGZED2HDZg9hy2YPacNmQQ/+4GYP/vFmD/7oSDnIdbxmQQ9+
            4WYPfvhmD3DEVUGJ20EBwWYPfvBmQQ9+wkEBwWYPcMdVZg9+6EEBwWYPfsBmD3DGVUEBwmYPfsBmD3DFVUEBwmYPfsBmD2/EZg9qxEEBwmYPcOT/ZkEPfsBmD2/HZg9wzv9mD2rHZg9+wGYPb8ZmD2rGQQHAZg9+wGYPb8VmD2rFQQHA
            Zg9+wGYPcMX/QQHAZg9+4GYPcOf/Zg9+4QHIZg9+yQHBZg9+wAHBSItEJGhIAdBBOd90ZQ+2OEEB+Q+2eAFBAfoPtngCQQH4D7Z4AwH5QY17AUE5/35CD7Z4BEGDwwJBAfkPtngFQQH6D7Z4BkEB+A+2eAcB+UU5334eRA+2WAhFAdlE
            D7ZYCUUB2kQPtlgKD7ZAC0UB2AHBQY1GAUwB6kE5xA+E+wEAAEGJxukz/v//Dx8ARIt8JHCDRCQ8AYt8JDSLRCQ8AXwkMDlEJCwPj8D9//+DRCQcAYt8JAiLRCQcAXwkGDlEJAwPhab6//8xwA8otCSQAAAADyi8JKAAAABEDyiEJLAA
            AABIjWXIW15fQVxBXUFeQV9dw2YPH4QAAAAAAIt8JChEichEiXQkcJlIi7QkgAAAAEgDdRhEiX049/9JifNBicFEidCZQQ+28ff/QYnCRInAmff/QYnAicgxyZlBic5FD7bgTInZ9/+DfCRUAkEPtvoPtthJid8PhhABAAAPH4AAAAAA
            D7bQSItcJFhIweIITAniSY0MG0jB4ghICfpIweIISAnySMHiCEwJ+kjB4ghMCeJIweIISAn6SMHiCEgJ8kiJlCSAAAAASImUJIgAAABMidoPH4QAAAAAAGYPb7QkgAAAAEiDwhAPEXLwSDnRdepIi1wkYEmNDBuLXCRAO104dGREi204
            QSndQYP9AXRJD7bQSMHiCEwJ4kjB4ghICfpIweIISAnySMHiCEwJ+kjB4ghMCeJIweIISAn6SMHiCEgJ8kmJFJtEieqD4v6J00iNDJlBOdV0DkSICUSIUQFEiEECiEEDQY1WAUwDXCR4RDl0JHAPhLD7//+DfCRUAkGJ1kyJ2Q+H9/7/
            /zHb6XD///8PH4QAAAAAAIt8JChEichIi7QkgAAAADHbmUgDdRj3/0mJ80GJwUSJ0Jn3/0GJwkSJwJn3/0GJwInImff/RYX/D4TX/f//D7bIg3wkdAJFD7bgQQ+2+kSJdCRQQQ+28UGJ3kSJfCRwSYnPTInZD4YIAQAADx9EAAAPttBI
            i1wkSEjB4ghMCeJJjQwbSMHiCEgJ+kjB4ghICfJIweIITAn6SMHiCEwJ4kjB4ghICfpIweIISAnySImUJIAAAABIiZQkiAAAAEyJ2mYPb6wkgAAAAEiDwhAPEWrwSDnKdepIi1wkaEmNDBuLXCREOVwkcHRlRItsJHBBKd1Bg/0BdEkP
            ttBIweIITAniSMHiCEgJ+kjB4ghICfJIweIITAn6SMHiCEwJ4kjB4ghICfpIweIISAnySYkUm0SJ6oPi/onTSI0MmUE51XQORIgJRIhRAUSIQQKIQQNBjVYBTANcJHhEO3QkUA+Ervz//4N8JHQCQYnWTInZD4f9/v//Mdvpb////0Ux
            2+kO/P//x0QkPAAAAADpKvr//7j/////6bT8//+QkJCQkJCQ
            )"            
         }
         mCodeFunc := BitMap.GetMcodePtr(x64)
      }

      GDIp.GetImageDimensions(TpBitmapIn, &Width, &Height)
      pBitmapOut := GDIp.CreateBitmap(Width, Height)
      If (Width != GDIp.GetImageWidth(pBitmapOut) || Height != GDIp.GetImageHeight(pBitmapOut))
         Return -1

      If (BlockSize > Width || BlockSize > Height)
         Return -2
      ; Copy to new bitmap
      E1 := GDIp.LockBits(TpBitmapIn, 0, 0, Width, Height, &Stride1, &Scan01, &BitmapData1)
      E2 := GDIp.LockBits(pBitmapOut, 0, 0, Width, Height, &Stride2, &Scan02, &BitmapData2)
      If (E1 || E2)
         Return -3

      ; E := - unused exit code
      DllCall(mCodeFunc, "Ptr", Scan01, "Ptr", Scan02, "int", Width, "int", Height, "int", Stride1, "int", BlockSize)
      GDIp.UnlockBits(TpBitmapIn, &BitmapData1)
      GDIp.UnlockBits(pBitmapOut, &BitmapData2)
      ; Get rid of input bitmap
      GDIp.DisposeImage(TpBitmapIn)

      Return pBitmapOut
   }


   /**
    * BoxBlurMultiPass
    * @param TpBitmapIn 
    * @param kernel size
    * @returns pBitmapOut
    */

   Static BoxBlurMultiPass(TpBitmapIn, kernel, passses := 3) {
      Static mCodeFunc := 0
      If (mCodeFunc = 0) {
         ; -m64 -O3 -fPIC -fno-stack-protector -fno-plt -fno-asynchronous-unwind-tables (O3 is bigger code)
         If (A_PtrSize = 8) {
            x64 := "
            (
            VUiJ5UFXQVZBVUFUV1ZTSIPk8EiB7GABAACLRTCLXTiLdUCJTCRESImUJAgBAABMiUQkSImEJDABAACJnCRcAQAAibQkNAEAAEiF0g+E7QcAAE2FwA+E5AcAAIXAD47cBwAAhdsPjtQHAACF9g+OzAcAAIXJD47EBwAA0fiJwonY0fg5
