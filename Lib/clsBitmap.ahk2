            QSndQYP9AXRJD7bQSMHiCEwJ4kjB4ghICfpIweIISAnySMHiCEwJ+kjB4ghMCeJIweIISAn6SMHiCEgJ8kmJFJtEieqD4v6J00iNDJlBOdV0DkSICUSIUQFEiEECiEEDQY1WAUwDXCR4RDl0JHAPhLD7//+DfCRUAkGJ1kyJ2Q+H9/7/
            /zHb6XD///8PH4QAAAAAAIt8JChEichIi7QkgAAAADHbmUgDdRj3/0mJ80GJwUSJ0Jn3/0GJwkSJwJn3/0GJwInImff/RYX/D4TX/f//D7bIg3wkdAJFD7bgQQ+2+kSJdCRQQQ+28UGJ3kSJfCRwSYnPTInZD4YIAQAADx9EAAAPttBI
            i1wkSEjB4ghMCeJJjQwbSMHiCEgJ+kjB4ghICfJIweIITAn6SMHiCEwJ4kjB4ghICfpIweIISAnySImUJIAAAABIiZQkiAAAAEyJ2mYPb6wkgAAAAEiDwhAPEWrwSDnKdepIi1wkaEmNDBuLXCREOVwkcHRlRItsJHBBKd1Bg/0BdEkP
            ttBIweIITAniSMHiCEgJ+kjB4ghICfJIweIITAn6SMHiCEwJ4kjB4ghICfpIweIISAnySYkUm0SJ6oPi/onTSI0MmUE51XQORIgJRIhRAUSIQQKIQQNBjVYBTANcJHhEO3QkUA+Ervz//4N8JHQCQYnWTInZD4f9/v//Mdvpb////0Ux
            2+kO/P//x0QkPAAAAADpKvr//7j/////6bT8//+QkJCQkJCQ
            )"            
         }
         mCodeFunc := BitMap.GetMcodePtr(x64)
      }

      GDIp.GetImageDimensions(TpBitmapIn, &Width, &Height)
      pBitmapOut := GDIp.CreateBitmap(Width, Height)
      If (Width != GDIp.GetImageWidth(pBitmapOut) || Height != GDIp.GetImageHeight(pBitmapOut))
         Return -1

      If (BlockSize > Width || BlockSize > Height)
         Return -2
      ; Copy to new bitmap
      E1 := GDIp.LockBits(TpBitmapIn, 0, 0, Width, Height, &Stride1, &Scan01, &BitmapData1)
      E2 := GDIp.LockBits(pBitmapOut, 0, 0, Width, Height, &Stride2, &Scan02, &BitmapData2)
      If (E1 || E2)
         Return -3

      ; E := - unused exit code
      DllCall(mCodeFunc, "Ptr", Scan01, "Ptr", Scan02, "int", Width, "int", Height, "int", Stride1, "int", BlockSize)
      GDIp.UnlockBits(TpBitmapIn, &BitmapData1)
      GDIp.UnlockBits(pBitmapOut, &BitmapData2)
      ; Get rid of input bitmap
      GDIp.DisposeImage(TpBitmapIn)

      Return pBitmapOut
   }


   /**
