            i1wkVIt0JCAx0ot8JBiLRCQQA0QkFI22AAAAAIsLg8IBg8MQiAiLS/SISAGLS/iISAKLS/yISAMB8DnXf96DRCREAYtEJEQ5RCQcD4+D/v//i0QkWIkEJOgAAAAAi0QkXImEJIAAAACDxGxbXl9d6QAAAACLRCRY6+eQkJCQkJCQkJCQ
            |msvcrt:_malloc:159:4|msvcrt:_malloc:586:4|msvcrt:_free:1013:4|msvcrt:_free:1036:4
            )"            
            mCodeFunc := BitMap.GetMcodePtr(x86)
            return
         }
      }
      ; get dimensions and reference to first pixel in memory (iScan)
      If (mCodeFunc) {
         GDIp.GetImageDimensions(TpBitmapIn, &w, &h)
         GDIp.LockBits(TpBitmapIn, 0, 0, w, h, &stride, &iScan, &iData, 3, 0x26200A) ; 3 is read/write for in-place editing
         ; Gdip_GaussianBlurBitmap(unsigned char * pBitmap, int w, int h, int Stride, int KernelSize
         r := DllCall(mCodeFunc, "UPtr", iScan, "uInt", stride, "uint", w, "uint", h, "uInt", kernel//2-1)
         GDIp.UnlockBits(TpBitmapIn, &iData)
         Return TpBitmapIn
      } Else {
         elog("Failed to compile MCode")
         Return 0
      }

   }


   /**
    * Apply a Gaussian blur to a pBitmap in place using compiled machine code.
    * Produces better results than BlurBitmap for text content.
    * License: MIT - Author: Edison Hua (iseahound) - https://github.com/iseahound/TextRender
    * @param {Integer} TpBitmapIn Handle to the pBitmap to blur (modified in place)
    * @param {Integer} radius Blur radius; controls the convolution kernel size
    * @param {Float} opacity Opacity factor for the blur result (default: 1)
    * @returns {Integer} pBitmap handle (same as input, modified in place)
    */
   Static MCodeGaussianBlur(TpBitmapIn, radius, opacity := 1) {
      Static code := (A_PtrSize = 4)
         ? "
